<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cargo_product_preset_list" model="ir.ui.view">
        <field name="name">cargo.architect.product.preset.list</field>
        <field name="model">cargo.architect.product.preset</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="product_tmpl_id"/>
                <field name="length_in"/>
                <field name="width_in"/>
                <field name="height_in"/>
                <field name="weight_lbs"/>
                <field name="allow_rotate"/>
                <field name="stackable"/>
            </list>
        </field>
    </record>
    <record id="view_cargo_product_preset_form" model="ir.ui.view">
        <field name="name">cargo.architect.product.preset.form</field>
        <field name="model">cargo.architect.product.preset</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_id"/>
                <field name="product_tmpl_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Cargo Dimensions">
                        <field name="length_in"/>
                        <field name="width_in"/>
                        <field name="height_in"/>
                        <field name="weight_lbs"/>
                    </group>
                    <group string="Rules">
                        <field name="allow_rotate"/>
                        <field name="stackable"/>
                        <field name="max_stack"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
