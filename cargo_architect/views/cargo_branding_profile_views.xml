<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cargo_branding_profile_list" model="ir.ui.view">
        <field name="name">cargo.architect.branding.profile.list</field>
        <field name="model">cargo.architect.branding.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="primary_color"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_cargo_branding_profile_form" model="ir.ui.view">
        <field name="name">cargo.architect.branding.profile.form</field>
        <field name="model">cargo.architect.branding.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="active"/>
                            <field name="footer_text"/>
                        </group>
                        <group>
                            <field name="logo" widget="image"/>
                            <field name="primary_color"/>
                            <field name="secondary_color"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_cargo_branding_profile" model="ir.actions.act_window">
        <field name="name">Branding Profiles</field>
        <field name="res_model">cargo.architect.branding.profile</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
